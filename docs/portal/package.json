{
  "name": "@paliwallet/docs-portal",
  "version": "1.0.0",
  "private": true,
  "description": "Documentation portal for Pali Wallet users, dapp developers, and institutional passkey integrators.",
  "scripts": {
    "start": "docusaurus start --host 0.0.0.0",
    "start:locale": "docusaurus start --host 0.0.0.0 --locale",
    "build": "docusaurus build",
    "build:en": "docusaurus build --locale en",
    "serve": "docusaurus serve --host 0.0.0.0",
    "preview": "yarn build && yarn serve",
    "write-translations": "docusaurus write-translations",
    "clear": "docusaurus clear"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/module-type-aliases": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@easyops-cn/docusaurus-search-local": "^0.55.2",
    "clsx": "^2.1.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
